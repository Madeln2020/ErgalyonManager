# ═══════════════════════════════════════════════════════════════════
# EDM v2.1 — Environment Variables (copy to .env for local dev)
# ═══════════════════════════════════════════════════════════════════
# Usage:  cp .env.example .env   # then edit values
# ═══════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────
APP_NAME=EDM v2.1
APP_VERSION=2.1.0
ENVIRONMENT=development        # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8887

# ── CORS (comma-separated origins) ───────────────────────────────
CORS_ORIGINS=http://localhost:8887,http://localhost:3000,http://localhost:3001

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edm_v2
POSTGRES_USER=edm
POSTGRES_PASSWORD=edm_password
DATABASE_URL=postgresql+asyncpg://edm:edm_password@localhost:5432/edm_v2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MinIO / S3-compatible Object Store ──────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=edm-uploads
MINIO_SECURE=false
MINIO_REGION=us-east-1

# ── Security / JWT ───────────────────────────────────────────────
SECRET_KEY=change-me-in-production        # generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440          # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800                 # 50 MB in bytes

# ── Parsing & OCR ────────────────────────────────────────────────
OCR_LANGUAGE=ell+eng                      # Greek + English
PARSING_CONFIDENCE_THRESHOLD=0.8
TESSERACT_CMD=/usr/bin/tesseract
PDF_MAX_PAGES=500

# ── Product Identity (v2.1) ──────────────────────────────────────
# Product Identity = Supplier Code + Supplier ID (NOT Pylon Code)
PRODUCT_IDENTITY_USE_PYLON_CODE=false

# ── Enrichment Order (v2.1) ──────────────────────────────────────
# XML -> Manual -> Web Scraping (last resort)
ENRICHMENT_ORDER=xml,manual,web_scrape

# ── Cost Protection (v2.1) ───────────────────────────────────────
# Existing costs are NEVER overwritten without explicit user approval
COST_PROTECTION_ENABLED=true

# ── FreeLLM API (primary AI provider for RAG + chat) ────────────
FREELLM_API_KEY=
FREELLM_BASE_URL=
FREELLM_EMBEDDING_MODEL=auto
FREELLM_CHAT_MODEL=deepseek-ai/deepseek-v4-pro
FREELLM_MAX_RETRIES=3
FREELLM_TIMEOUT=60

# ── Hermes / AI Routing ─────────────────────────────────────────
HERMES_LOCAL_LLM_URL=http://localhost:11434
HERMES_PRIVACY_LOCAL_ONLY=true

# ── Web Scraping ─────────────────────────────────────────────────
CRAWL4AI_TIMEOUT=30
CRAWL4AI_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36

# ── Multi-Tenancy (v2.1) ─────────────────────────────────────────
# Every table includes a company_id column for logical isolation
MULTI_TENANCY_ENABLED=true

# ── Audit Trail (v2.1) ───────────────────────────────────────────
# Every change is logged in audit_logs table
AUDIT_LOG_ENABLED=true

# ── Poimenidis First Test Case (v2.1) ────────────────────────────
# Strip "03-" prefix from supplier codes for Poimenidis
POIMENIDIS_STRIP_03_PREFIX=true

# ── Prometheus Metrics ───────────────────────────────────────────
METRICS_ENABLED=true

# ── Gemini API (for Vision parsing) ────────────────────────
# Used by vision_parser.py for image-to-text extraction.
# Get a key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ── FreeLLM Vision Model (optional) ────────────────────────
# If your FreeLLMAPI endpoint supports vision (image input), set the model here.
# Otherwise, leave blank and the system will use Gemini for vision.
FREELLM_VISION_MODEL=
