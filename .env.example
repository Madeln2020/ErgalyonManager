# ===========================================================================
# EDM v2 — Παράδειγμα μεταβλητών περιβάλλοντος (αντιγράψτε σε .env)
# ===========================================================================

# --- API ---
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me

# --- PostgreSQL (+ pgvector) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edm
POSTGRES_USER=edm
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://edm:change-me@localhost:5432/edm

# --- Redis (queue / broker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edm-uploads
S3_REGION=us-east-1

# --- Hermes / AI routing ---
HERMES_LOCAL_LLM_URL=http://localhost:11434
FREELLM_API_KEY=
ABACUS_API_KEY=
# Privacy policy: payloads με ΑΦΜ/tax ids -> local only
HERMES_PRIVACY_LOCAL_ONLY=true

# --- OCR ---
TESSERACT_CMD=/usr/bin/tesseract
