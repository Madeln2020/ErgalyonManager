# EDM v2 — Environment Configuration
# Copy to .env and fill in values

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://edm:edm_password@localhost:5432/edm_v2

# Redis (Celery)
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Server
HOST=0.0.0.0
PORT=8887
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:8887,http://localhost:3000

# Upload Directory
UPLOAD_DIR=./uploads
