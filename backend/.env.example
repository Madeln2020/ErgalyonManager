# ═══════════════════════════════════════════════════════════════════
# EDM v2 – Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to `.env` and adjust for your local or production
# environment.  Never commit `.env` to version control.
#
#   cp .env.example .env
#
# ── Required (must set for app to boot) ─────────────────────────────

# Application
APP_NAME=EDM v2
ENVIRONMENT=development          # "development" or "production"
DEBUG=true                       # false in production
HOST=0.0.0.0
PORT=8887
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://edm:edm_password@localhost:5432/edm_v2
# └─ Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>

# Redis (caching / Celery / rate limiting)
REDIS_URL=redis://localhost:6379/0

# ── FreeLLM API (RAG — embeddings search + LLM enrichment) ─────────────
# Your self-hosted FreeLLM endpoint (replaces Gemini)
FREELLM_API_KEY=frellmapi-476bb0962f21fd33c29a125cfa205b6689b9bd825cc689c9
FREELLM_BASE_URL=http://176.9.105.236:3001/v1
FREELLM_EMBEDDING_MODEL=auto  # "auto" or specific model from Embeddings tab

# ── Feature Flags (Phase 5: Gradual Rollout) ───────────────────────
# Set FEATURE_<NAME>=true to enable a feature.
# Example:
# FEATURE_BULK_EXPORT_V2=true
# FEATURE_NEW_DASHBOARD=true
# FEATURE_AUTO_CATEGORIZE=true